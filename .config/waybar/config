{
  "layer": "top",
  "modules-left": [
    "custom/arch",
    "sway/mode",
    "wlr/taskbar",
    "sway/window"
  ],
  "modules-center": [
    "clock",
    "memory"
  ],
  "modules-right": [
    "group/notifications",
    "tray"
  ],
  "tray": {
    "icon-size": 20,
    "spacing": 10
  },
  "custom/spotify": {
    "exec": "$HOME/.config/waybar/scripts/spotify.sh",
    "max-length": 40,
    "format": " {}",
    "on-click": "sleep 0.1 && eww open --toggle dashboard",
    "tooltip": false
  },
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 27,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "markup": true,
    "active-first": true,
    "tooltip": false,
    "on-click-middle": "close",
    "ignore-list": [],
    "app_ids-mapping": {
      "firefoxdeveloperedition": "firefox-developer-edition"
    },
    "rewrite": {
      "Firefox Web Browser": "Firefox",
      "Foot Server": "Terminal"
    }
  },
  "sway/window": {
    "format": "{title}",
    "max-length": 50,
    "rewrite": {
      "(.*) - Mozilla Firefox": "рҹҢҺ $1",
      "(.*) - vim": "оҹ… $1",
      "(.*) - zsh": "п„  [$1]"
    }
  },
  "sway/workspaces": {
    "disable-scroll": false,
    "all-outputs": true,
    "format": "{icon}",
    "format-icons": {
      "1": "рҹҢҺ ",
      "2": "оҳ« ",
      "3": "пҒ» ",
      "4": "оһЈ",
      "5": "пҖҪ ",
      "6": "у°ІҮ",
      "7": "пӢҶ ",
      "8": "пғӯ ",
      "9": "пҮҝ",
      "10": "пӢ’ ",
      "urgent": "пҒӘ ",
      "focused": "пҶ’ ",
      "default": "п„‘ "
    }
  },
  "wlr/workspaces": {
    "format": "{icon}",
    "on-click": "activate",
    "format-icons": {
      "1": "п„ ",
      "2": "пүЁ",
      "3": "п„Ў",
      "4": "пҶј",
      "5": "пҒө",
      "urgent": "пҒӘ",
      "active": "пҶ’",
      "default": "п„‘"
    },
    "sort-by-number": true
  },
  "memory": {
    "interval": 30,
    "format": "{used:0.1f}G/{total:0.1f}G оҝ…"
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "пғ§",
      "performance": "пғ§",
      "balanced": "пүҺ",
      "power-saver": "пҒ¬"
    }
  },
  "sway/mode": {
    "format": "пҚқ {}",
    "max-length": 50
  },
  "sway/language": {
    "format": "{short} пҶ«в Җ"
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "пҒ® "
    },
    "temperature": {
      "critical-threshold": 80,
      "format": "{temperatureC}В°C {icon}",
      "format-icons": [
        "пӢҠ",
        "пӢү",
        "пӢҮ"
      ]
    }
  },
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "у°ғһ",
      "у°ғ "
    ],
    "on-scroll-up": "light -A 1",
    "on-scroll-down": "light -U 1"
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "tooltip-format": "{timeTo}, {capacity}%",
    "format-charging": "у°Ӯ„ {capacity}%",
    "on-click-middle": "adios --ab",
    "format-plugged": "пҮҰ ",
    "format-alt": "{time} {icon}",
    "format-icons": [
      "пүғ",
      "пүғ",
      "пүӮ",
      "пүҒ",
      "пүҖ"
    ]
  },
  "network": {
    "interface": "wlan0",
    "interval": 10,
    "format-wifi": "у°–© {essid} {bandwidthDownBytes}",
    "format-ethernet": "{ifname}: {ipaddr}/{cidr} оҪ„ ",
    "format-linked": "{ifname} (No IP) оҪ„ ",
    "format-disconnected": "пӘ© ",
    "format-alt": "{ifname}: {ipaddr}/{cidr}",
    "tooltip-format": "{essid} {signalStrength}%"
  },
  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon} пҠ”",
    "format-muted": "пҖҰ",
    "format-icons": {
      "headphone": "пҖҘ",
      "hands-free": "у°Ӣҗ",
      "headset": "у°ӢҚ",
      "phone": "пӮ•",
      "portable": "пӮ•",
      "car": "пҶ№",
      "default": [
        "пҖ§",
        "пҖЁ"
      ]
    },
    "scroll-step": 1,
    "on-click": "pavucontrol",
    "ignored-sinks": [
      "Easy Effects Sink"
    ]
  },
  "custom/media": {
    "format": "{icon} {}",
    "return-type": "json",
    "max-length": 40,
    "format-icons": {
      "spotify": "пҶј ",
      "default": "пҖҒ "
    },
    "escape": true,
    "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null",
    "on-click": "playerctl play-pause"
  },
  "custom/fans": {
    "format": "{}",
    "exec": "$HOME/.config/waybar/fans.sh",
    "escape": true,
    "restart-interval": 10
  },
  "custom/arch": {
    "format": "{icon}",
    "on-click": "sirula",
    "return-type": "json",
    "format-icons": {
      "arch": "пҢғ ",
      "default": "пҢғ "
    }
  },
  "custom/notification": {
    "escape": true,
    "exec": "swaync-client -swb",
    "exec-if": "which swaync-client",
    "format": " {icon} ",
    "format-icons": {
      "dnd-inhibited-none": "у°Ӯҡ<sup>п„‘</sup>",
      "dnd-inhibited-notification": "у°Ӯҡ<span foreground='#f38ba8'><sup>п„‘</sup></span>",
      "dnd-none": "у°Ӯӣ",
      "dnd-notification": "у°Ӯӣ<span foreground='#f38ba8'><sup>п„‘</sup></span>",
      "inhibited-none": "у°Ӯҡ<sup>у°ңә</sup>",
      "inhibited-notification": "у°өҷ<span foreground='#f38ba8'><sup>п„‘</sup></span>",
      "none": "у°Ӯҡ<span color='#6c7086'><sup>п„‘</sup></span>",
      "notification": "у°Ӯҡ<span foreground='#f38ba8'><sup>п„‘</sup></span>"
    },
    "on-click": "sleep 0.1 && swaync-client -t -sw",
    "on-click-right": "sleep 0.1 && swaync-client -d -sw",
    "return-type": "json",
    "tooltip": false
  },
  "group/notifications": {
    "orientation": "horizontal",
    "modules": [
      "pulseaudio",
      "custom/notification",
      "battery",
      "network"
    ]
  },
  "custom/updates": {
    "format": "{icon} {}",
    "return-type": "json",
    "format-icons": {
      "has-updates": "уұҚ·",
      "updated": "у°ӮӘ"
    },
    "exec-if": "which waybar-module-pacman-updates",
    "exec": "waybar-module-pacman-updates"
  },
  "custom/wl-gammarelay-temperature": {
    "format": "{} пҶҶ",
    "exec": "wl-gammarelay --subscribe Temperature",
    "on-scroll-up": "busctl --user -- call rs.wl-gammarelay / rs.wl.gammarelay UpdateTemperature n +100",
    "on-scroll-down": "busctl --user -- call rs.wl-gammarelay / rs.wl.gammarelay UpdateTemperature n -100"
  },
  "custom/wl-gammarelay-brightness": {
    "format": "{} пғ«",
    "exec": "wl-gammarelay --subscribe Brightness",
    "on-scroll-up": "busctl --user -- call rs.wl-gammarelay / rs.wl.gammarelay UpdateBrightness d +0.02",
    "on-scroll-down": "busctl --user -- call rs.wl-gammarelay / rs.wl.gammarelay UpdateBrightness d -0.02"
  }
}
