{
  "layer": "top",
  "modules-left": [
    "custom/arch",
    "sway/mode",
    "wlr/taskbar",
    "sway/window"
  ],
  "modules-center": [
    "clock",
    "memory",
    "custom/spotify"
  ],
  "modules-right": [
    "group/notifications",
    "tray"
  ],
  "tray": {
    "icon-size": 20,
    "spacing": 10
  },
  "custom/spotify": {
    "exec": "$HOME/.config/waybar/scripts/spotify.sh",
    "max-length": 40,
    "format": " {}",
    "on-click": "sleep 0.1 && eww open --toggle dashboard",
    "tooltip": false
  },
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 27,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "markup": true,
    "active-first": true,
    "tooltip": false,
    "on-click-middle": "close",
    "ignore-list": [],
    "app_ids-mapping": {
      "firefoxdeveloperedition": "firefox-developer-edition"
    },
    "rewrite": {
      "Firefox Web Browser": "Firefox",
      "Foot Server": "Terminal"
    }
  },
  "clock": {
    "format": "{:%H:%M} ΎΑΩ ",
    "format-alt": "{:L%A, %B %d, %Y (%R)} ΎΩψ ",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-scroll-up": "tz_up",
      "on-scroll-down": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },
  "sway/window": {
    "format": "{title}",
    "max-length": 50,
    "rewrite": {
      "(.*) - Mozilla Firefox": "ΏθΝΟ $1",
      "(.*) - vim": "ΌθΖ $1",
      "(.*) - zsh": "ΎΕι [$1]"
    }
  },
  "sway/workspaces": {
    "disable-scroll": false,
    "all-outputs": true,
    "format": "{icon}",
    "format-icons": {
      "1": "ΏθΝΟ ",
      "2": "Όατ ",
      "3": "ΎΒ╗ ",
      "4": "Όημ",
      "5": "ΎΑ╜ ",
      "6": "≤░▓Θ",
      "7": "ΎΜΗ ",
      "8": "ΎΔφ ",
      "9": "ΎΘ┐",
      "10": "ΎΜΤ ",
      "urgent": "ΎΒς ",
      "focused": "ΎΗΤ ",
      "default": "ΎΕΣ "
    }
  },
  "wlr/workspaces": {
    "format": "{icon}",
    "on-click": "activate",
    "format-icons": {
      "1": "ΎΕι",
      "2": "ΎΚρ",
      "3": "ΎΕκ",
      "4": "ΎΗ╝",
      "5": "ΎΒ╡",
      "urgent": "ΎΒς",
      "active": "ΎΗΤ",
      "default": "ΎΕΣ"
    },
    "sort-by-number": true
  },
  "memory": {
    "interval": 30,
    "format": "{used:0.1f}G/{total:0.1f}G Ό┐Ζ"
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "ΎΔπ",
      "performance": "ΎΔπ",
      "balanced": "ΎΚΟ",
      "power-saver": "ΎΒυ"
    }
  },
  "sway/mode": {
    "format": "ΎΞζ {}",
    "max-length": 50
  },
  "sway/language": {
    "format": "{short} ΎΗτέιΑ"
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "ΎΒχ "
    },
    "temperature": {
      "critical-threshold": 80,
      "format": "{temperatureC}┬░C {icon}",
      "format-icons": [
        "ΎΜΛ",
        "ΎΜΚ",
        "ΎΜΘ"
      ]
    }
  },
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "≤░Δη",
      "≤░Δι"
    ],
    "on-scroll-up": "light -A 1",
    "on-scroll-down": "light -U 1"
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "tooltip-format": "{timeTo}, {capacity}%",
    "format-charging": "≤░ΓΕ {capacity}%",
    "on-click-middle": "adios --ab",
    "format-plugged": "ΎΘο ",
    "format-alt": "{time} {icon}",
    "format-icons": [
      "ΎΚΔ",
      "ΎΚΔ",
      "ΎΚΓ",
      "ΎΚΒ",
      "ΎΚΑ"
    ]
  },
  "network": {
    "interface": "wlan0",
    "interval": 10,
    "format-wifi": "≤░Ψσ {essid} {bandwidthDownBytes}",
    "format-ethernet": "{ifname}: {ipaddr}/{cidr} Ό╜Ε ",
    "format-linked": "{ifname} (No IP) Ό╜Ε ",
    "format-disconnected": "Ύςσ ",
    "format-alt": "{ifname}: {ipaddr}/{cidr}",
    "tooltip-format": "{essid} {signalStrength}%"
  },
  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon} ΎΛΦ",
    "format-muted": "ΎΑο",
    "format-icons": {
      "headphone": "ΎΑξ",
      "hands-free": "≤░ΜΡ",
      "headset": "≤░ΜΞ",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": [
        "ΎΑπ",
        "ΎΑρ"
      ]
    },
    "scroll-step": 1,
    "on-click": "pavucontrol",
    "ignored-sinks": [
      "Easy Effects Sink"
    ]
  },
  "custom/media": {
    "format": "{icon} {}",
    "return-type": "json",
    "max-length": 40,
    "format-icons": {
      "spotify": "ΎΗ╝ ",
      "default": "ΎΑΒ "
    },
    "escape": true,
    "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null",
    "on-click": "playerctl play-pause"
  },
  "custom/fans": {
    "format": "{}",
    "exec": "$HOME/.config/waybar/fans.sh",
    "escape": true,
    "restart-interval": 10
  },
  "custom/arch": {
    "format": "{icon}",
    "on-click": "sirula",
    "return-type": "json",
    "format-icons": {
      "arch": "ΎΝΔ ",
      "default": "ΎΝΔ "
    }
  },
  "custom/notification": {
    "escape": true,
    "exec": "swaync-client -swb",
    "exec-if": "which swaync-client",
    "format": " {icon} ",
    "format-icons": {
      "dnd-inhibited-none": "≤░Γγ<sup>ΎΕΣ</sup>",
      "dnd-inhibited-notification": "≤░Γγ<span foreground='#f38ba8'><sup>ΎΕΣ</sup></span>",
      "dnd-none": "≤░Γδ",
      "dnd-notification": "≤░Γδ<span foreground='#f38ba8'><sup>ΎΕΣ</sup></span>",
      "inhibited-none": "≤░Γγ<sup>≤░ε║</sup>",
      "inhibited-notification": "≤░╡β<span foreground='#f38ba8'><sup>ΎΕΣ</sup></span>",
      "none": "≤░Γγ<span color='#6c7086'><sup>ΎΕΣ</sup></span>",
      "notification": "≤░Γγ<span foreground='#f38ba8'><sup>ΎΕΣ</sup></span>"
    },
    "on-click": "sleep 0.1 && swaync-client -t -sw",
    "on-click-right": "sleep 0.1 && swaync-client -d -sw",
    "return-type": "json",
    "tooltip": false
  },
  "group/notifications": {
    "orientation": "horizontal",
    "modules": [
      "pulseaudio",
      "custom/notification",
      "battery",
      "network"
    ]
  },
  "custom/updates": {
    "format": "{icon} {}",
    "return-type": "json",
    "format-icons": {
      "has-updates": "≤▒Ξ╖",
      "updated": "≤░Γς"
    },
    "exec-if": "which waybar-module-pacman-updates",
    "exec": "waybar-module-pacman-updates"
  },
  "custom/wl-gammarelay-temperature": {
    "format": "{} ΎΗΗ",
    "exec": "wl-gammarelay --subscribe Temperature",
    "on-scroll-up": "busctl --user -- call rs.wl-gammarelay / rs.wl.gammarelay UpdateTemperature n +100",
    "on-scroll-down": "busctl --user -- call rs.wl-gammarelay / rs.wl.gammarelay UpdateTemperature n -100"
  },
  "custom/wl-gammarelay-brightness": {
    "format": "{} ΎΔτ",
    "exec": "wl-gammarelay --subscribe Brightness",
    "on-scroll-up": "busctl --user -- call rs.wl-gammarelay / rs.wl.gammarelay UpdateBrightness d +0.02",
    "on-scroll-down": "busctl --user -- call rs.wl-gammarelay / rs.wl.gammarelay UpdateBrightness d -0.02"
  }
}
